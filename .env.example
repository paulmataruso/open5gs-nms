# ═══════════════════════════════════════════════════════════
# Open5GS NMS - Environment Configuration
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and customize for your deployment
# Do NOT commit .env to version control (contains secrets)

# ───────────────────────────────────────────────────────────
# Network / Access
# ───────────────────────────────────────────────────────────
# The external IP or hostname users will access the app from.
# Informational only - used for reference in docs/scripts.
NMS_HOST=127.0.0.1

# Nginx listen port (web UI access)
NGINX_PORT=8888

# ───────────────────────────────────────────────────────────
# Backend Configuration
# ───────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
LOG_LEVEL=info

# ───────────────────────────────────────────────────────────
# Database Configuration
# ───────────────────────────────────────────────────────────
# MongoDB connection string for Open5GS subscriber database
# NOTE: This is the Open5GS MongoDB instance - do not point
# this at a separate database. NMS auth uses its own SQLite DB.
MONGODB_URI=mongodb://127.0.0.1:27017/open5gs

# ───────────────────────────────────────────────────────────
# Open5GS Paths
# ───────────────────────────────────────────────────────────
# Path to Open5GS configuration files
CONFIG_PATH=/etc/open5gs

# Path to store configuration backups
BACKUP_PATH=/etc/open5gs/backups/config

# Path to store MongoDB backups
MONGO_BACKUP_PATH=/etc/open5gs/backups/mongodb

# ───────────────────────────────────────────────────────────
# Authentication
# ───────────────────────────────────────────────────────────
# Path inside the container where auth.db (SQLite) is stored.
# Must match the ./data:/app/data volume mount in docker-compose.yml.
# The NMS creates and manages this file automatically.
AUTH_DB_PATH=/app/data/auth.db

# Session lifetime in seconds (default: 86400 = 24 hours)
SESSION_MAX_AGE=86400

# Set this on first deploy to control the initial admin password.
# If left empty, a random password is generated and printed once
# to the backend container logs - check with:
#   docker logs open5gs-nms-backend 2>&1 | grep -A4 "FIRST RUN"
# Clear or remove this variable after your first login.
FIRST_RUN_PASSWORD=

# Set to 'true' ONLY when the app is served over HTTPS.
# Enabling this on plain HTTP will silently break login (browser won't store the cookie).
# Default: false (HTTP deployments work out of the box)
COOKIE_SECURE=false

# ───────────────────────────────────────────────────────────
# WebSocket Configuration
# ───────────────────────────────────────────────────────────
# Port for WebSocket server (real-time log streaming)
WS_PORT=3002

# ───────────────────────────────────────────────────────────
# Internal Service Ports
# ───────────────────────────────────────────────────────────
# BACKEND_PORT and FRONTEND_PORT are internal container-to-container
# ports — they are never exposed to the outside world.
#
# What you actually connect to:
#   http://YOUR_SERVER_IP:8888  — everything (web UI + API + SAS HTTP)
#   https://YOUR_SERVER_IP:8443 — SAS HTTPS only (Sercomm radios)
#
# Port 8888 is nginx, which internally proxies to:
#   FRONTEND_PORT (8081) — the React frontend server
#   BACKEND_PORT  (3001) — the Node.js API server
#
# Only change these if you have a port conflict on the host,
# and update docker-compose.yml + nginx.conf to match.
BACKEND_PORT=3001
FRONTEND_PORT=8081

# ───────────────────────────────────────────────────────────
# System Integration
# ───────────────────────────────────────────────────────────
# Path to systemctl binary on host system
HOST_SYSTEMCTL_PATH=/usr/bin/systemctl

# ───────────────────────────────────────────────────────────
# Monitoring (Prometheus + Grafana)
# ───────────────────────────────────────────────────────────
# Grafana admin credentials (set before first docker compose up)
# Defaults: admin / open5gs
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=open5gs

# Prometheus port (default 9099 — NOT 9090, which Open5GS NFs already use for metrics)
PROMETHEUS_PORT=9099

# Grafana port (default 3000)
GRAFANA_PORT=3000

# Prometheus config path (relative to project root) — auto-updated by NMS on apply
PROMETHEUS_CONFIG_PATH=./monitoring/prometheus.yml

# Prometheus base URL used by backend to trigger live reload
# Defaults to http://127.0.0.1:${PROMETHEUS_PORT} if not set
# PROMETHEUS_URL=http://127.0.0.1:9099

# Access:
#   Prometheus: http://YOUR_SERVER_IP:${PROMETHEUS_PORT}
#   Grafana:    http://YOUR_SERVER_IP:${GRAFANA_PORT}

# ───────────────────────────────────────────────────────────
# UI Module Toggles
# ───────────────────────────────────────────────────────────
# Enable/disable optional UI modules — hides them from the nav sidebar and
# disables their page entirely. true/false only.
# NOTE: these are baked into the frontend at build time — changing them
# requires: docker compose build frontend && docker compose up -d frontend
ENABLE_SMS_MODULE=true
ENABLE_IMS_MODULE=true
ENABLE_VALIDATION_MODULE=true
ENABLE_VOWIFI_MODULE=true
ENABLE_DNS_MIGRATION_MODULE=true
ENABLE_PCAP_MODULE=true

# ───────────────────────────────────────────────────────────
# GenieACS (TR-069 ACS)
# ───────────────────────────────────────────────────────────
# Secret used to sign GenieACS UI session JWTs.
# Change this to a long random string before deploying.
# Generate one with: openssl rand -hex 32
GENIEACS_UI_JWT_SECRET=changeme_set_this_to_a_long_random_string

# GenieACS UI port (default 7000 — port 3000 is used by Grafana)
GENIEACS_UI_PORT=7000

# Access:
#   GenieACS UI:   http://YOUR_SERVER_IP:7000
#   CWMP (TR-069): http://YOUR_SERVER_IP:7547  <- point CPEs here
#   NBI (API):     http://YOUR_SERVER_IP:7557
#   FS (files):    http://YOUR_SERVER_IP:7567
# MongoDB DB used: genieacs  (separate from open5gs DB)

# ───────────────────────────────────────────────────────────
# Simlessly eSIM RSP API (Subscribers page — "Generate eSIM")
# ───────────────────────────────────────────────────────────
# Get these from the Developer module on your Simlessly account
# (https://docs.simlessly.com). Leave empty to disable live eSIM
# generation — the JSON preview/copy still works without them, only
# the "Generate via Simlessly API" button requires real credentials.
SIMLESSLY_ACCESS_KEY=
SIMLESSLY_SECRET_KEY=
