# ═══════════════════════════════════════════════════════════
# Open5GS NMS - Environment Configuration
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and customize for your deployment
# Do NOT commit .env to version control (contains secrets)

# ───────────────────────────────────────────────────────────
# Network / Access
# ───────────────────────────────────────────────────────────
# The external IP or hostname users will access the app from.
# Informational only - used for reference in docs/scripts.
NMS_HOST=127.0.0.1

# Nginx listen port (web UI access)
NGINX_PORT=8888

# ───────────────────────────────────────────────────────────
# Backend Configuration
# ───────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
LOG_LEVEL=info

# ───────────────────────────────────────────────────────────
# Database Configuration
# ───────────────────────────────────────────────────────────
# MongoDB connection string for Open5GS subscriber database
# NOTE: This is the Open5GS MongoDB instance - do not point
# this at a separate database. NMS auth uses its own SQLite DB.
MONGODB_URI=mongodb://127.0.0.1:27017/open5gs

# ───────────────────────────────────────────────────────────
# Open5GS Paths
# ───────────────────────────────────────────────────────────
# Path to Open5GS configuration files
CONFIG_PATH=/etc/open5gs

# Path to store configuration backups
BACKUP_PATH=/etc/open5gs/backups/config

# Path to store MongoDB backups
MONGO_BACKUP_PATH=/etc/open5gs/backups/mongodb

# ───────────────────────────────────────────────────────────
# Authentication
# ───────────────────────────────────────────────────────────
# Path inside the container where auth.db (SQLite) is stored.
# Must match the ./data:/app/data volume mount in docker-compose.yml.
# The NMS creates and manages this file automatically.
AUTH_DB_PATH=/app/data/auth.db

# Session lifetime in seconds (default: 86400 = 24 hours)
SESSION_MAX_AGE=86400

# Set this on first deploy to control the initial admin password.
# If left empty, a random password is generated and printed once
# to the backend container logs - check with:
#   docker logs open5gs-nms-backend 2>&1 | grep -A4 "FIRST RUN"
# Clear or remove this variable after your first login.
FIRST_RUN_PASSWORD=

# Set to 'true' ONLY when the app is served over HTTPS.
# Enabling this on plain HTTP will silently break login (browser won't store the cookie).
# Default: false (HTTP deployments work out of the box)
COOKIE_SECURE=false

# ───────────────────────────────────────────────────────────
# WebSocket Configuration
# ───────────────────────────────────────────────────────────
# Port for WebSocket server (real-time log streaming)
WS_PORT=3002

# ───────────────────────────────────────────────────────────
# Internal Service Ports
# ───────────────────────────────────────────────────────────
# These match the hardcoded values in docker-compose.yml and
# nginx.conf. Only change if you have a port conflict and
# update all three files consistently.
BACKEND_PORT=3001
FRONTEND_PORT=8080

# ───────────────────────────────────────────────────────────
# System Integration
# ───────────────────────────────────────────────────────────
# Path to systemctl binary on host system
HOST_SYSTEMCTL_PATH=/usr/bin/systemctl
