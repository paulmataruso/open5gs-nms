{
  "title": "Open5GS Network Dashboard",
  "uid": "open5gs-main",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "tags": ["open5gs", "5g", "4g", "epc"],
  "panels": [

    { "id": 1, "type": "row", "title": "🌐 Network Overview", "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }, "collapsed": false },

    {
      "id": 2, "type": "stat", "title": "Active 5G Sessions (AMF)",
      "gridPos": { "x": 0, "y": 1, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 200 }] }, "unit": "short", "mappings": [] } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "open5gs-prometheus" }, "expr": "amf_session", "legendFormat": "AMF Sessions", "refId": "A" }]
    },

    {
      "id": 3, "type": "stat", "title": "Active 4G Sessions (MME)",
